{
  "manifest_version": 3,
  "name": "KotobaTab",
  "version": "1.0",
  "description": "Aprenda uma frase em japonês por dia com um tema escuro de sakura.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
